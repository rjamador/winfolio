# Copy this file to `.env` and fill in real values.
# All client-exposed vars MUST be prefixed with VITE_.
# Validated at startup by src/lib/env.ts — the app fails fast if a required
# var is missing or malformed.

# Base URL for the projects API/CMS. Optional while the
# app runs on local data; set it when connecting a real backend.
# VITE_API_BASE_URL=https://api.example.com
